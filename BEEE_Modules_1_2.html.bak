            </tr>
            <tr>
              <td><strong>Primary Target</strong></td>
              <td>Wiring and equipment</td>
              <td>Human life safety</td>
              <td>Industrial machinery, heavy distribution panels</td>
            </tr>
            <tr>
              <td><strong>Where Used</strong></td>
              <td>Household distribution boards</td>
              <td>In domestic/commercial panels with MCBs</td>
